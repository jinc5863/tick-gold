# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tick_gold
DB_USER=postgres
DB_PASSWORD=postgres
DB_TYPE=timescaledb

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MT5 API配置
MT5_HOST=127.0.0.1
MT5_PORT=1611
MT5_LOGIN=your_mt5_login
MT5_PASSWORD=your_mt5_password

# API配置
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# 安全配置
SECRET_KEY=your_secret_key_here
JWT_EXPIRATION=3600

# 数据源配置
DATA_SOURCE=MT5
HISTORICAL_DATA_SOURCE=Dukascopy

# 性能配置
MAX_TICK_RATE=21340
TARGET_LATENCY=50

# 合规配置
AUDIT_ENABLED=true
RISK_MONITORING=true

# UI配置
THEME=neumorphism
DARK_MODE=true

# 警告：请勿将此文件提交到版本控制，请创建.env文件并添加实际值
# Warning: Do not commit this file to version control, create .env file with actual values