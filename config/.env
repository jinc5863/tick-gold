# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tickgold
DB_USER=postgres
DB_PASSWORD=password
DB_TYPE=postgresql

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=RedisPassword123

# MT5 API配置
MT5_HOST=mt5
MT5_PORT=1611
MT5_LOGIN=admin
MT5_PASSWORD=admin

# API配置
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# 安全配置
SECRET_KEY=tick_gold_default_secret_key_change_in_production_12345
JWT_EXPIRATION=3600

# 数据源配置
DATA_SOURCE=MT5
HISTORICAL_DATA_SOURCE=Dukascopy

# 性能配置
MAX_TICK_RATE=21340
TARGET_LATENCY=50

# 合规配置
AUDIT_ENABLED=true
RISK_MONITORING=true

# UI配置
THEME=neumorphism
DARK_MODE=true

# 开发环境特定配置
NODE_ENV=development
PYTHONUNBUFFERED=1
TAURI_DEV=true

# 警告：请在生产环境中更改以下敏感值
# SECRET_KEY, DB_PASSWORD, MT5_PASSWORD